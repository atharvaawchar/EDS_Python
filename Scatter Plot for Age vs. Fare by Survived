import pandas as pd
import matplotlib.pyplot as plt

# Load the Titanic dataset
data = pd.read_csv('Titanic-Dataset.csv')

# Data Cleaning
data['Age'].fillna(data['Age'].median(), inplace=True)
data['Embarked'].fillna(data['Embarked'].mode()[0], inplace=True)
data.drop('Cabin', axis=1, inplace=True)

# Convert categorical features to numeric
data['Sex'] = data['Sex'].map({'male': 0, 'female': 1})
data = pd.get_dummies(data, columns=['Embarked'], drop_first=True)

# Scatter Plot for Age vs. Fare by Survived
plt.figure(figsize=(8,6))
colors = {0: 'red', 1: 'green'}  # 0 = Did not survive, 1 = Survived
labels = {0: 'Did Not Survive', 1: 'Survived'}

for survived in data['Survived'].unique():
    subset = data[data['Survived'] == survived]
    plt.scatter(subset['Age'], subset['Fare'],
                c=colors[survived], label=labels[survived], alpha=0.6)

plt.title('Scatter Plot of Age vs. Fare by Survival Status')
plt.xlabel('Age')
plt.ylabel('Fare')
plt.legend()
plt.grid(True)
plt.show()
